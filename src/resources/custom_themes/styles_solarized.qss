QWidget { background: #002b36; color: #eee8d5; }
QMainWindow, QDialog { background: #002b36; }
QLineEdit, QComboBox, QTextEdit, QPlainTextEdit { background: #073642; color: #eee8d5; border: 1px solid #586e75; border-radius: 4px; padding: 4px; }
QPushButton { background: #586e75; border: 1px solid #657b83; padding: 6px 10px; }
QTreeWidget::item:selected { background: #268bd2; color: #002b36; }